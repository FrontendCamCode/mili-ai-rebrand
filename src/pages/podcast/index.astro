---
import { getCollection } from "astro:content";
import SiteShell from "../../components/SiteShell.astro";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path: string) => `${base}${path.replace(/^\//, "")}`;

const episodes = (await getCollection("podcast")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
---

<SiteShell
  title="Podcast"
  description="Short, practical conversations about maintenance, MRO, and indirect material supply chain management from Tim and Justin at Lexin Solutions."
>
  <main>
    <section class="page-hero page-hero--podcast">
      <div class="page-hero-inner page-hero-inner--wide">
        <p class="eyebrow">Podcast</p>
        <h1>The Lexin Podcast.</h1>
        <p class="hero-lede">Short, practical conversations about the work of managing indirect material supply chains in asset-intensive industries. Hosted by Tim and Justin at Lexin Solutions.</p>
      </div>
    </section>

    <section class="listing-shell">
      <div class="listing-grid">
        {episodes.map((episode) => (
          <a href={href(`podcast/${episode.slug}`)} class="listing-card listing-card--episode">
            <span class="listing-eyebrow">Podcast</span>
            <h2>{episode.data.title}</h2>
            <p>{episode.data.description}</p>
            <footer class="listing-card-meta">
              {episode.data.duration && <span class="listing-duration">{episode.data.duration}</span>}
              <time datetime={episode.data.publishedAt.toISOString()}>
                {episode.data.publishedAt.toLocaleDateString("en", { day: "numeric", month: "short", year: "numeric" })}
              </time>
              {episode.data.guest && <span>with {episode.data.guest}</span>}
            </footer>
          </a>
        ))}
      </div>
    </section>
  </main>
</SiteShell>
