---
import { getCollection } from "astro:content";
import SiteShell from "../../components/SiteShell.astro";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path: string) => `${base}${path.replace(/^\//, "")}`;

export async function getStaticPaths() {
  const episodes = await getCollection("podcast");
  return episodes.map((episode) => ({
    params: { slug: episode.slug },
    props: { episode },
  }));
}

const { episode } = Astro.props;
const { Content } = await episode.render();

const related = (await getCollection("podcast"))
  .filter((e) => e.slug !== episode.slug)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
---

<SiteShell
  title={episode.data.title}
  description={episode.data.description}
  canonical={`${import.meta.env.SITE ?? ""}${base}podcast/${episode.slug}`}
>
  <main>
    <section class="page-hero page-hero--podcast">
      <div class="page-hero-inner">
        <p class="eyebrow">Podcast</p>
        <h1>{episode.data.title}</h1>
        <p class="hero-lede">{episode.data.description}</p>
        <div class="hero-meta">
          {episode.data.duration && <span class="hero-meta-pill">{episode.data.duration}</span>}
          {episode.data.guest && <span>with {episode.data.guest}</span>}
          <time datetime={episode.data.publishedAt.toISOString()}>
            {episode.data.publishedAt.toLocaleDateString("en", { day: "numeric", month: "long", year: "numeric" })}
          </time>
        </div>
        {episode.data.embedUrl && (
          <a href={episode.data.embedUrl} class="btn btn-lime" style="margin-top:28px;" target="_blank" rel="noopener">
            Listen to episode
          </a>
        )}
      </div>
    </section>

    <article class="prose-shell">
      <div class="prose">
        <Content />
      </div>
    </article>

    {related.length > 0 && (
      <section class="related-section">
        <div class="related-inner">
          <h2>More Episodes</h2>
          <div class="listing-grid listing-grid--compact">
            {related.map((ep) => (
              <a href={href(`podcast/${ep.slug}`)} class="listing-card listing-card--episode">
                <span class="listing-eyebrow">Podcast</span>
                <h3>{ep.data.title}</h3>
                {ep.data.duration && <span class="listing-duration">{ep.data.duration}</span>}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</SiteShell>
