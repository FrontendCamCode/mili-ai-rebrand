---
import { getCollection } from "astro:content";
import SiteShell from "../../components/SiteShell.astro";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path: string) => `${base}${path.replace(/^\//, "")}`;

export async function getStaticPaths() {
  const episodes = await getCollection("podcast");
  return episodes.map((episode) => ({
    params: { slug: episode.slug },
    props: { episode },
  }));
}

const { episode } = Astro.props;
const { Content } = await episode.render();

const related = (await getCollection("podcast"))
  .filter((e) => e.slug !== episode.slug)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

// Normalise embed URLs to embeddable form
function toEmbedUrl(url: string | undefined): string | null {
  if (!url) return null;
  // YouTube
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]+)/);
  if (yt) return `https://www.youtube.com/embed/${yt[1]}?rel=0`;
  // Vimeo
  const vi = url.match(/vimeo\.com\/(\d+)/);
  if (vi) return `https://player.vimeo.com/video/${vi[1]}`;
  // Already an embed URL or other service — pass through
  if (url.startsWith("http")) return url;
  return null;
}

const embedUrl = toEmbedUrl(episode.data.embedUrl);
---

<SiteShell
  title={episode.data.title}
  description={episode.data.description}
  canonical={`${import.meta.env.SITE ?? ""}${base}podcast/${episode.slug}`}
>
  <main>
    <!-- ── Hero: two-column title + player ── -->
    <section class="page-hero page-hero--podcast">
      <div class="podcast-hero-grid">
        <div class="podcast-hero-copy">
          <p class="eyebrow">Podcast</p>
          <h1>{episode.data.title}</h1>
          <p class="hero-lede">{episode.data.description}</p>
          <div class="hero-meta">
            {episode.data.duration && <span class="hero-meta-pill">{episode.data.duration}</span>}
            {episode.data.guest && <span>with {episode.data.guest}</span>}
            <time datetime={episode.data.publishedAt.toISOString()}>
              {episode.data.publishedAt.toLocaleDateString("en", { day: "numeric", month: "long", year: "numeric" })}
            </time>
          </div>
        </div>

        <!-- Player / placeholder -->
        <div class="podcast-player-wrap">
          {embedUrl ? (
            <iframe
              src={embedUrl}
              title={episode.data.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          ) : (
            <div class="podcast-player-placeholder">
              <div class="podcast-play-btn" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <p class="podcast-player-label">The Tim &amp; Justin Show</p>
              <p class="podcast-player-title">{episode.data.title}</p>
              {episode.data.duration && (
                <p class="podcast-player-label">{episode.data.duration}</p>
              )}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- ── Body: prose + sticky sidebar ── -->
    <div class="article-shell">
      <div class="article-body">
        <article class="prose">
          <Content />
        </article>

        <aside class="article-sidebar">
          <div class="author-card">
            <p class="author-card-label">Your hosts</p>

            <div class="author-avatar" style="margin-bottom:14px;">
              <div class="author-initials">TM</div>
              <div>
                <p class="author-name">Tim McLain</p>
                <p class="author-role">Co-founder, Lexin Solutions</p>
              </div>
            </div>
            <p class="author-bio" style="margin-bottom:20px;">
              Supply chain specialist with extensive experience in MRO materials management, procurement strategy, and ERP implementation across mining, oil &amp; gas, and heavy manufacturing.
            </p>

            <div class="author-avatar" style="margin-bottom:14px;">
              <div class="author-initials">JL</div>
              <div>
                <p class="author-name">Justin Lester</p>
                <p class="author-role">Co-founder, Lexin Solutions</p>
              </div>
            </div>
            <p class="author-bio">
              Maintenance and EAM specialist with 15+ years connecting maintenance operations to supply chain strategy in asset-intensive industries.
            </p>

            {episode.data.guest && (
              <>
                <div style="height:1px;background:var(--line);margin:20px 0;"></div>
                <p class="author-card-label">Guest</p>
                <div class="author-avatar">
                  <div class="author-initials" style="background:var(--teal);">
                    {episode.data.guest.split(" ").map((n: string) => n[0]).join("").slice(0,2).toUpperCase()}
                  </div>
                  <div>
                    <p class="author-name">{episode.data.guest}</p>
                  </div>
                </div>
              </>
            )}
          </div>
        </aside>
      </div>
    </div>

    {related.length > 0 && (
      <section class="related-section">
        <div class="related-inner">
          <h2>More Episodes</h2>
          <div class="listing-grid listing-grid--compact">
            {related.map((ep) => (
              <a href={href(`podcast/${ep.slug}`)} class="listing-card listing-card--episode">
                <span class="listing-eyebrow">Podcast</span>
                <h3>{ep.data.title}</h3>
                {ep.data.duration && <span class="listing-duration">{ep.data.duration}</span>}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</SiteShell>
