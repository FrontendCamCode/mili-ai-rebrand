---
import { getCollection } from "astro:content";
import SiteShell from "../../components/SiteShell.astro";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path: string) => `${base}${path.replace(/^\//, "")}`;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = (await getCollection("blog"))
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const authors: Record<string, { initials: string; role: string; bio: string }> = {
  "Justin Lester": {
    initials: "JL",
    role: "Co-founder, Lexin Solutions",
    bio: "Justin brings deep operational expertise in EAM, CMMS, and maintenance management across asset-intensive industries. With 15+ years in the field, he specialises in connecting maintenance operations to supply chain strategy — and has spent his career helping organisations get more from the systems they already own.",
  },
  "Tim McLain": {
    initials: "TM",
    role: "Co-founder, Lexin Solutions",
    bio: "Tim is a supply chain specialist with extensive experience in MRO materials management, procurement strategy, and ERP implementation. He has worked across mining, oil & gas, and heavy manufacturing helping organisations reduce working capital, eliminate free-text spend, and build supply chains that actually support maintenance.",
  },
};

const authorName = post.data.author ?? "";
const authorInfo = authors[authorName] ?? null;
---

<SiteShell
  title={post.data.title}
  description={post.data.description}
  canonical={`${import.meta.env.SITE ?? ""}${base}blog/${post.slug}`}
>
  <main>
    <section class="page-hero">
      <div class="page-hero-inner">
        <p class="eyebrow">Article</p>
        <h1>{post.data.title}</h1>
        <p class="hero-lede">{post.data.description}</p>
        <div class="hero-meta">
          {authorName && <span>{authorName}</span>}
          <time datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toLocaleDateString("en", { day: "numeric", month: "long", year: "numeric" })}
          </time>
          {post.data.tags?.map((tag) => <span class="hero-meta-pill">{tag}</span>)}
        </div>
      </div>
    </section>

    <div class="article-shell">
      <div class="article-body">
        <article class="prose">
          <Content />
        </article>

        <aside class="article-sidebar">
          {authorInfo && (
            <div class="author-card">
              <p class="author-card-label">Written by</p>
              <div class="author-avatar">
                <div class="author-initials">{authorInfo.initials}</div>
                <div>
                  <p class="author-name">{authorName}</p>
                  <p class="author-role">{authorInfo.role}</p>
                </div>
              </div>
              <p class="author-bio">{authorInfo.bio}</p>
            </div>
          )}
        </aside>
      </div>
    </div>

    {allPosts.length > 0 && (
      <section class="related-section">
        <div class="related-inner">
          <h2>More Articles</h2>
          <div class="listing-grid listing-grid--compact">
            {allPosts.map((p) => (
              <a href={href(`blog/${p.slug}`)} class="listing-card">
                <span class="listing-eyebrow">Article</span>
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</SiteShell>
