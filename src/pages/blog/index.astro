---
import { getCollection } from "astro:content";
import SiteShell from "../../components/SiteShell.astro";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path: string) => `${base}${path.replace(/^\//, "")}`;

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
---

<SiteShell
  title="Articles"
  description="Field notes and practical guidance on indirect material supply chain management from the Lexin Solutions team."
>
  <main>
    <section class="page-hero">
      <div class="page-hero-inner page-hero-inner--wide">
        <p class="eyebrow">Articles</p>
        <h1>Field notes from the front line.</h1>
        <p class="hero-lede">Practical guidance on MRO, maintenance, and indirect material supply chain management — written by practitioners for practitioners.</p>
      </div>
    </section>

    <section class="listing-shell">
      <div class="listing-grid">
        {posts.map((post) => (
          <a href={href(`blog/${post.slug}`)} class="listing-card">
            <span class="listing-eyebrow">Article</span>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <footer class="listing-card-meta">
              <time datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString("en", { day: "numeric", month: "short", year: "numeric" })}
              </time>
              {post.data.author && <span>{post.data.author}</span>}
            </footer>
          </a>
        ))}
      </div>
    </section>
  </main>
</SiteShell>
