---
import SiteShell from "../../components/SiteShell.astro";
import { features } from "../../data/features";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path: string) => `${base}${path.replace(/^\//, "")}`;

export function getStaticPaths() {
  return Object.keys(features).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const feature = features[slug as string]!
---

<SiteShell
  title={`${feature.label} — MiLi`}
  description={feature.tagline}
  canonical={`${import.meta.env.SITE ?? ""}${base}features/${slug}`}
>
  <main>
    <section class="page-hero">
      <div class="page-hero-inner">
        <p class="eyebrow">MiLi Feature</p>
        <h1>{feature.label}</h1>
        <p class="hero-lede">{feature.tagline}</p>
      </div>
    </section>

    <div class="feature-page-shell">
      <div class="feature-page-body">
        <p class="feature-page-desc">{feature.description}</p>

        <ul class="feature-page-bullets">
          {feature.bullets.map((b) => <li>{b}</li>)}
        </ul>

        <div class="feature-page-cta">
          <a href={href("contact")} class="primary-cta">Book a pilot</a>
          <a href={href("mili#features")} class="secondary-cta">All features</a>
        </div>
      </div>
    </div>
  </main>
</SiteShell>
