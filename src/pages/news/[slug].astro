---
import { getCollection } from "astro:content";
import SiteShell from "../../components/SiteShell.astro";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path: string) => `${base}${path.replace(/^\//, "")}`;

export async function getStaticPaths() {
  const items = await getCollection("news");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
---

<SiteShell
  title={item.data.title}
  description={item.data.description}
  canonical={`${import.meta.env.SITE ?? ""}${base}news/${item.slug}`}
>
  <main>
    <section class="page-hero">
      <div class="page-hero-inner page-hero-inner--narrow">
        <p class="eyebrow">News</p>
        <h1>{item.data.title}</h1>
        <p class="hero-lede">{item.data.description}</p>
        <div class="hero-meta">
          <time datetime={item.data.publishedAt.toISOString()}>
            {item.data.publishedAt.toLocaleDateString("en", { day: "numeric", month: "long", year: "numeric" })}
          </time>
          {item.data.source && <span>{item.data.source}</span>}
          {item.data.sourceUrl && (
            <a href={item.data.sourceUrl} target="_blank" rel="noopener" class="article-source-link">
              View source →
            </a>
          )}
        </div>
      </div>
    </section>

    <article class="prose-shell">
      <div class="prose">
        <Content />
      </div>
    </article>

    <section class="related-section">
      <div class="related-inner">
        <a href={href("news")} class="back-link">← All News</a>
      </div>
    </section>
  </main>
</SiteShell>
