---
import SiteShell from "./SiteShell.astro";
import type { StaticPage } from "../data/sitemap";

export interface Props {
  page: StaticPage;
}

const { page } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path = "") => (/^(https?:|mailto:|#)/.test(path) ? path : `${base}${path.replace(/^\//, "")}`);

const isResource = page.kind === "resource";
const heroVariant =
  page.slug === "trust"   ? "page-hero--trust"   :
  page.slug === "mili"    ? "page-hero--feature"  :
  (isResource || page.slug === "contact") ? "page-hero--light" :
  "";

const ctaBand = page.slug !== "success" && page.slug !== "popcorn";
---

<SiteShell title={page.title} description={page.description}>
  <main>
    <section class:list={["page-hero", heroVariant]}>
      <div class="page-hero-inner">
        {page.eyebrow && <p class="eyebrow">{page.eyebrow}</p>}
        <h1>{page.title}</h1>
        {page.description && <p class="hero-lede">{page.description}</p>}
        {page.ctaLabel && (
          <a
            class:list={["btn", heroVariant === "page-hero--light" ? "btn-dark" : "btn-lime"]}
            style="margin-top:28px;"
            href={href(page.ctaHref ?? "contact")}
          >
            {page.ctaLabel}
          </a>
        )}
      </div>
    </section>

    {ctaBand && (
      <section class="cta-band">
        <div class="cta-band-inner">
          <div>
            <h2>Ready to see MiLi with your data?</h2>
            <p>A dedicated pilot environment loaded with your real inventory — so your team can see exactly what MiLi finds before committing.</p>
          </div>
          <a class="btn btn-lime" href="mailto:info@lexinsolutions.com">Book a pilot</a>
        </div>
      </section>
    )}
  </main>
</SiteShell>
