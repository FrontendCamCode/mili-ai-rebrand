---
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path: string) =>
  /^(https?:|mailto:|#)/.test(path) ? path : `${base}${path.replace(/^\//, "")}`;
const year = new Date().getFullYear();
---

<div class="footer-bg">
  <footer class="footer-shell">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src={href("images/lexin-logo-reverse.png")} alt="Lexin Solutions" width="144" height="32" />
        <p>Lexin Solutions helps asset-intensive industries optimize indirect material supply chains from demand signal to inventory to supply.</p>
        <p class="footer-compliance">SOC 2 Type II &nbsp;·&nbsp; ISO 27001 &nbsp;·&nbsp; SAP Certified</p>
      </div>

      <nav class="footer-col" aria-label="Platform">
        <strong>Platform</strong>
        <a href={href("mili")}>MiLi Overview</a>
        <a href={href("mili#features")}>All Features</a>
        <a href={href("mili#pilot")}>Book a Pilot</a>
        <a href={href("mili#compare")}>How it Compares</a>
        <a href={href("trust")}>Trust &amp; Security</a>
      </nav>

      <nav class="footer-col" aria-label="Resources">
        <strong>Resources</strong>
        <a href={href("blog")}>Articles</a>
        <a href={href("podcast")}>Podcast</a>
        <a href={href("news")}>News</a>
        <a href={href("resources/capability-uplift")}>Capability Uplift</a>
        <a href={href("resources/scaas")}>Supply Chain as a Service</a>
      </nav>

      <nav class="footer-col" aria-label="Company">
        <strong>Company</strong>
        <a href="https://www.lexinsolutions.com/" target="_blank" rel="noopener">Lexin Solutions</a>
        <a href={href("contact")}>Contact Us</a>
        <a href={href("pilot")}>Request a Pilot</a>
        <a href="https://www.lexinsolutions.com/trust" target="_blank" rel="noopener">Trust Center</a>
        <a href="mailto:info@lexinsolutions.com">info@lexinsolutions.com</a>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>© {year} Lexin Solutions Pty Ltd. All rights reserved.</p>
      <nav aria-label="Legal">
        <a href="https://www.lexinsolutions.com/trust" target="_blank" rel="noopener">Privacy</a>
        <a href="https://www.lexinsolutions.com/trust" target="_blank" rel="noopener">Terms</a>
        <a href={href("trust")}>Security</a>
      </nav>
    </div>
  </footer>
</div>
